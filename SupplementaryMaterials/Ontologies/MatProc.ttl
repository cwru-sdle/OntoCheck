mds:MeltTemperature a owl:Class ;
    rdfs:label "Melt Temperature"@en ;
    rdfs:subClassOf mds:ProcessingTemperature ;
    skos:definition "The temperature of molten material during processing."@en ;
    mds:hasDomain "Manufacture"@en ;
    mds:hasStudyStage "Process" ;
    mds:hasSubDomain "MatProc"@en ;
