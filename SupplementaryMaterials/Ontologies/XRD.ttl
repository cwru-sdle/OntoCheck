    rdfs:subClassOf mds:XrayDetector .

mds:PixelHeight a owl:Class ;
    rdfs:label "Pixel Height" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "Number of pixels in height of the detector." .

mds:PixelSizeHeight a owl:Class ;
    rdfs:label "Pixel Size Height" ;
    rdfs:subClassOf cco:ont00000738 ;
    skos:definition "Physical height of individual pixels." .

mds:PixelSizeWidth a owl:Class ;
    rdfs:label "Pixel Size Width" ;
    rdfs:subClassOf cco:ont00000738 ;
    skos:definition "Physical width of individual pixels." .

mds:PixelWidth a owl:Class ;
    rdfs:label "Pixel Width" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "Number of pixels in width of the detector." .

mds:PointGreyFlea3 a owl:Class ;
    rdfs:label "Point Grey Flea3 (13Y3M-C)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:PolarizationCorrection a owl:Class ;
    rdfs:label "PolarizationCorrection" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "do_polarization_correction" ;
    skos:definition "Boolean flag indicating whether to apply polarization correction to account for the polarization state." .

mds:PolarizationFactor a owl:Class ;
    rdfs:label "PolarizationFactor" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "polarization_factor" ;
    skos:definition "Numerical factor specifying the degree of polarization correction to apply." .

mds:PredictionOutput a owl:Class ;
    rdfs:label "Prediction Output"@en ;
    rdfs:comment "An information content entity representing the output predictions from a neural network."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:PrincetonQuadro a owl:Class ;
    rdfs:label "7541-0005 (Princeton Quadro)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:PriorBetaGrain a owl:Class ;
    rdfs:label "Prior Beta Grain"@en ;
    rdfs:subClassOf obo:BFO_0000040 ;
    skos:definition "A region of a polycrystalline material corresponding to a single beta-phase grain that existed at high temperature before solid-state transformation to alpha or alpha-prime. Prior beta grain boundaries persist as microstructural features after transformation and constrain the morphology and distribution of daughter alpha variants."@en .

mds:RT41 a owl:Class ;
    rdfs:label "2304879 (RT41)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:RadialRange a owl:Class ;
    rdfs:label "RadialRange" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "radial_range" ;
    skos:definition " The minimum and maximum radial values to include in the integration." .

mds:ReadOutTime a owl:Class ;
    rdfs:label "Read Out Time" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "Read out time of the detector." .

mds:RecrystallizationDisposition a owl:Class ;
    rdfs:label "Recrystallization Disposition"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000055 ;
            owl:someValuesFrom mds:Recrystallization ],
        obo:BFO_0000016 ;
    skos:definition "A disposition of a deformed material to undergo recrystallization when sufficient thermal energy is supplied, dependent on stored strain energy and temperature."@en .

mds:RemoveNaN a owl:Class ;
    rdfs:label "RemoveNaN" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "do_remove_nan" ;
    skos:definition "Boolean flag controlling whether to exclude NaN." .

mds:Retiga4000DC a owl:Class ;
    rdfs:label "Retiga 4000DC" ;
    rdfs:subClassOf mds:XrayDetector .

mds:SafetyBrickAssembly a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A dense material assembly positioned upstream of the monochromator to provide radiation shielding for personnel safety." .

mds:SampleID a owl:Class ;
    rdfs:label "SampleID" ;
    rdfs:subClassOf cco:ont00000292 ;
    skos:definition "Unique ID of a sample." .

mds:SampleVerticalOrientation a owl:Class ;
    rdfs:label "Sample rotation vertical" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "bome" ;
    skos:definition "The vertical angular orientation of a sample relative to the gravitational axis." .

mds:SampleXPosition a owl:Class ;
    rdfs:label "Sample x-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "bsampX" ;
    skos:definition "The horizontal positioning of a sample along the X-axis in the laboratory coordinate system." .

mds:SampleYPosition a owl:Class ;
    rdfs:label "Sample y-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "bsampY" ;
    skos:definition "The horizontal positioning of a sample along the Y-axis in the laboratory coordinate system." .

mds:SampleZPosition a owl:Class ;
    rdfs:label "Sample z-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "bsampZ" ;
    skos:definition "The positioning of a sample along the Z-axis, typically parallel to the beam direction." .

mds:SinglePeakFitting a owl:Class ;
    rdfs:label "Single Peak Fitting"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001921 ;
            owl:someValuesFrom mds:IntegratedDiffractionPattern ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        cco:ont00000345 ;
    skos:definition "A quantitative analysis method that fits individual diffraction peaks to determine peak position (2-theta), intensity, and breadth (FWHM) as a function of azimuthal angle and time, enabling tracking of orientation-dependent lattice strain and peak width evolution during in-situ experiments."@en .

mds:SlitAssembly a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A multi-blade aperture system that precisely controls X-ray beam size and position through coordinated movement of multiple slit blades." .

mds:SlitTransversePosition a owl:Class ;
    rdfs:label "Slit x position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "s1x" ;
    skos:definition "The horizontal positioning of a slit blade perpendicular to the beam direction." .

mds:SlitVerticalBladesBottomPosition a owl:Class ;
    rdfs:label "Slit blades bottom" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "s1b" ;
    skos:definition "The positioning of the lower vertical blade in a slit assembly to control the bottom boundary of the beam aperture." .

mds:SlitVerticalBladesLeftPosition a owl:Class ;
    rdfs:label "Slit blades left" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "s1l" ;
    skos:definition "The positioning of the left vertical blade in a slit assembly to control the left boundary of the beam aperture." .

mds:SlitVerticalBladesRightPosition a owl:Class ;
    rdfs:label "Slit blades right" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "s1r" ;
    skos:definition "The positioning of the right vertical blade in a slit assembly to control the right boundary of the beam aperture." .

mds:SlitVerticalBladesTopPosition a owl:Class ;
    rdfs:label "Slit blades top" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "s1t" ;
    skos:definition "The positioning of the upper vertical blade in a slit assembly to control the top boundary of the beam aperture." .

mds:SlitVerticalPosition a owl:Class ;
    rdfs:label "Slit z position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "s1z" ;
    skos:definition "The vertical positioning of a slit blade parallel to the gravitational axis." .

mds:SolidAngleCorrection a owl:Class ;
    rdfs:label "SolidAngleCorrection" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "do_solid_angle_correction" ;
    skos:definition "Boolean parameter controlling whether to correct for solid angle effects." .

mds:SolutePartitioning a owl:Class ;
    rdfs:label "Solute Partitioning"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        obo:BFO_0000015 ;
    skos:definition "A diffusion-controlled process in which solute atoms redistribute between coexisting phases toward their respective equilibrium concentrations."@en .

mds:SolutionizationTemperature a owl:Class ;
    rdfs:label "Solutionization Temperature"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001769 ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:decimal ;
                    owl:withRestrictions ( [ xsd:minInclusive 900.0 ] ) ] ],
        cco:ont00000441 ;
    skos:definition "The temperature at which a material is held during solutionization treatment."@en .

mds:Spring8 a owl:Class ;
    rdfs:label "SPring-8" ;
    rdfs:subClassOf mds:SynchrotronFacility ;
    skos:definition "Super Photon ring-8 GeV synchrotron facility in Japan." .

mds:StrainDecomposition a owl:Class ;
    rdfs:label "Strain Decomposition"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001921 ;
            owl:someValuesFrom mds:IntegratedDiffractionPattern ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ChemicalStrain ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ThermalStrain ],
        cco:ont00000345 ;
    skos:definition "An analysis process that separates the total observed lattice strain into thermal expansion and non-thermal-expansion (chemical + mechanical) components by subtracting the contribution of the coefficient of thermal expansion from the total strain."@en .

mds:Supersaturation a owl:Class ;
    rdfs:label "Supersaturation"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A quality representing the excess of solute concentration in a phase beyond its equilibrium solubility at a given temperature."@en .

mds:SyncXrayPreProcessing a owl:Class ;
    rdfs:label "PreProcessing" ;
    rdfs:subClassOf cco:ont00001158 ;
    skos:definition "Preprocessing performed on the raw diffraction patterns obtained from the tool." .

mds:SyncXrayResult a owl:Class ;
    rdfs:subClassOf cco:ont00000958 .

mds:SyncXrayTool a owl:Class ;
    rdfs:label "XrayTool" ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A tool or instrument that lets users perform x-ray based experiments." .

mds:TTTDiagram a owl:Class ;
    rdfs:label "Time-Temperature-Transformation Diagram"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:altLabel "TTT Diagram"@en ;
    skos:definition "An information content entity representing the isothermal transformation kinetics of a material by plotting the time required for specified fractions of transformation at each temperature. In Ti-6Al-4V, separate TTT diagrams may be constructed for alpha phase fraction and beta-phase vanadium concentration, which may differ due to decoupled structural and compositional transformation (Whitney et al. 2024)."@en .

mds:TestDatasetSpecification a owl:Class ;
    rdfs:label "Test Dataset Specification"@en ;
    rdfs:comment "An information content entity that specifies the data used for testing a trained neural network."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:ThermalContraction a owl:Class ;
    rdfs:label "Thermal Contraction"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ResidualStressState ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ThermalStrain ],
        obo:BFO_0000015 ;
    skos:definition "A process in which the dimensions of a material decrease due to a decrease in temperature."@en .

mds:ThermalExpansion a owl:Class ;
    rdfs:label "Thermal Expansion"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ResidualStressState ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ThermalStrain ],
        obo:BFO_0000015 ;
    skos:definition "A process in which the dimensions of a material increase due to an increase in temperature, reflecting increased atomic vibrational amplitude."@en .

mds:ThermalExpansionRelation a owl:Class ;
    rdfs:label "Thermal Expansion Relation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom cco:ont00000441 ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:LatticeParameter ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:CoefficientOfThermalExpansion ],
        mds:GoverningLaw ;
    skos:definition "The relation describing how lattice parameters change with temperature due to anharmonic atomic vibrations: a(T) = a_0 * (1 + alpha * delta_T)."@en .

mds:ThermalProfile a owl:Class ;
    rdfs:label "Thermal Profile"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:altLabel "Thermal Cycle"@en ;
    skos:definition "An information content entity representing a prescribed or observed temperature-time history during a thermal process, including heating rate, hold temperature and duration, and cooling rate."@en .

mds:ToolID a owl:Class ;
    rdfs:label "ToolID" ;
    rdfs:subClassOf cco:ont00000292 ;
    skos:definition "Unique ID of the tool." .

mds:TopCaveSlitPosition a owl:Class ;
    rdfs:label "Top cave slit" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "cslitt" ;
    skos:definition "The positioning of the upper blade of a cave slit to control the vertical beam aperture from above." .

mds:TrainedNeuralNetworkModel a owl:Class ;
    rdfs:label "Trained Neural Network Model"@en ;
    rdfs:comment "An information content entity representing a trained neural network."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:TrainingDatasetSpecification a owl:Class ;
    rdfs:label "Training Dataset Specification"@en ;
    rdfs:comment "An information content entity that specifies the data used for training a neural network."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:TrainingEpoch a owl:Class ;
    rdfs:label "Training Epoch"@en ;
    rdfs:comment "A temporal part of training consisting of one complete pass through the training dataset."@en ;
    rdfs:subClassOf obo:0000015 .

mds:TrainingLossSpecification a owl:Class ;
    rdfs:label "Training Loss Specification"@en ;
    rdfs:comment "A measurement information content entity representing the loss function value during training."@en ;
    rdfs:subClassOf cco:ont00001163 .

mds:TransformationSusceptibility a owl:Class ;
    rdfs:label "Transformation Susceptibility"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000055 ;
            owl:someValuesFrom mds:PhaseTransformation ],
        obo:BFO_0000016 ;
    skos:definition "A disposition of a material to undergo a phase transformation under appropriate thermodynamic conditions (temperature, pressure, composition)."@en .

mds:TransusTemperature a owl:Class ;
    rdfs:label "Transus Temperature"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        cco:ont00000441 ;
    skos:definition "The temperature at which a phase transformation begins or is complete in an alloy."@en .

mds:TungstenRadiationShield a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A tungsten-based shield that absorbs scattered X-rays and protects equipment or personnel from radiation." .

mds:TungstenShieldHorizontalPosition a owl:Class ;
    rdfs:label "Tungsten shield horizontal position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "wx" ;
    skos:definition "The horizontal positioning of a tungsten radiation shield perpendicular to the beam direction." .

mds:TungstenShieldVerticalPosition a owl:Class ;
    rdfs:label "Tungsten shield vertical position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "wz" ;
    skos:definition "The vertical positioning of a tungsten radiation shield parallel to the gravitational axis." .

mds:Undulator a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A periodic magnetic structure that generates high-intensity X-ray radiation through electron beam oscillation in a synchrotron." .

mds:UndulatorPosition a owl:Class ;
    rdfs:label "Undulator position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "undulator" ;
    skos:definition "The magnetic gap or positional setting of an undulator that controls the X-ray energy spectrum." .

mds:UnitOfIntegration a owl:Class ;
    rdfs:label "Unit" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "unit" ;
    skos:definition "Integration units, either 2-theta or d." .

mds:ValidationAccuracySpecification a owl:Class ;
    rdfs:label "Validation Accuracy Specification"@en ;
    rdfs:comment "A measurement information content entity representing model accuracy on validation data."@en ;
    rdfs:subClassOf cco:ont00001163 .

mds:ValidationDatasetSpecification a owl:Class ;
    rdfs:label "Validation Dataset Specification"@en ;
    rdfs:comment "An information content entity that specifies the data used for validating a neural network during training."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:VegardsLaw a owl:Class ;
    rdfs:label "Vegard's Law"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:Concentration ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:LatticeParameter ],
        mds:GoverningLaw ;
    skos:definition "An empirical rule stating that the lattice parameter of a solid solution varies linearly with the atomic concentration of the solute. In Ti-6Al-4V, used to determine vanadium concentration in the beta phase from the lattice parameter: a([V]) = 3.278 A - 0.24*[V]_beta, where [V]_beta is vanadium concentration in weight percent (Brown et al. 2021)."@en .

mds:Vortex90EX a owl:Class ;
    rdfs:label "1348-VTX-90EX (Vortex)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:WavelengthRange a owl:Class ;
    rdfs:label "WavelengthRange" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The wavelength range the particular beamline can cover." .

mds:WroughtProcessing a owl:Class ;
    rdfs:label "Wrought Processing"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:EquilibriumSolidification ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:BimodalMorphology ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:EquiaxedMorphology ],
        mds:ProcessingMethod ;
    skos:altLabel "Conventional Processing"@en,
        "Wrought"@en ;
    skos:definition "A conventional thermomechanical manufacturing process involving bulk deformation (rolling, forging, extrusion) of cast ingot material, typically producing equiaxed or bimodal microstructures through repeated cycles of deformation and recrystallization."@en .

mds:XFlashME4_1 a owl:Class ;
    rdfs:label "XMAP (ME4-1) 267-VTX-ME4 (Vortex ME4-1)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:XFlashME4_2 a owl:Class ;
    rdfs:label "XMAP 267-VTX-ME4 (Vortex ME4-2)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:XrayDarkFieldPattern a owl:Class ;
    rdfs:label "DarkFile" ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:definition "Capturing one or more images with the detector under identical conditions to the sample measurement but without X-ray exposure,  recording only the electronic baseline and thermal noise.",
        "Capturing one or more images with the detector under identical conditions to the sample measurement but without X-ray exposure,  recording only the electronic baseline and thermal noise.." .

mds:XrayDiffractionPattern a owl:Class ;
    rdfs:subClassOf cco:ont00000958 .

mds:XrayRecipe a owl:Class ;
    rdfs:subClassOf obo:BFO_0000015 ;
    skos:definition "A process recipe for X-ray experiments." .

mds:XrayShutter a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A mechanical device that controls X-ray beam passage by blocking or allowing beam transmission through the beamline." .

mds:XrayShutterTransversePosition a owl:Class ;
    rdfs:label "Shutter transverse position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "shutx" ;
    skos:definition "The horizontal positioning of an X-ray shutter perpendicular to the beam direction." .

mds:XrayShutterVerticalPosition a owl:Class ;
    rdfs:label "Shutter vertical position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "shutz" ;
    skos:definition "The vertical positioning of an X-ray shutter parallel to the gravitational axis." .

mds:has_decoupled_kinetics_from a owl:ObjectProperty ;
    rdfs:label "has decoupled kinetics from"@en ;
    rdfs:comment "Indicates that the kinetics of one process (e.g., structural transformation) proceed at a different rate than another process (e.g., solute redistribution), such that the two processes do not reach completion simultaneously. Central finding: structural alpha formation precedes vanadium equilibration at isothermal hold temperatures at or below 865 C and all continuous cooling rates (Whitney et al. 2024)."@en ;
    rdfs:domain obo:BFO_0000015 ;
    rdfs:range obo:BFO_0000015 .

cco:ont00000324 a owl:Class ;
    rdfs:label "Width"@en ;
    skos:exactMatch cco:ont00000324 .

cco:ont00000472 a owl:Class ;
    rdfs:label "Geospatial Region"@en ;
    skos:exactMatch cco:ont00000472 .

cco:ont00000604 a owl:Class ;
    rdfs:label "Maximum Ordinal Measurement Information Content Entity"@en ;
    skos:exactMatch cco:ont00000604 .

cco:ont00000607 a owl:Class ;
    rdfs:label "Thickness"@en ;
    skos:exactMatch cco:ont00000607 .

cco:ont00001022 a owl:Class ;
    rdfs:label "Ratio Measurement Information Content Entity"@en ;
    skos:exactMatch cco:ont00001022 .

cco:ont00001149 a owl:Class ;
    rdfs:label "Data Range Interval Estimate Information Content Entity"@en ;
    skos:exactMatch cco:ont00001149 .

cco:ont00001765 a owl:DatatypeProperty ;
    rdfs:label "has text value"@en ;
    skos:exactMatch cco:ont00001765 .

cco:ont00001772 a owl:DatatypeProperty ;
    rdfs:label "has boolean value"@en ;
    skos:exactMatch cco:ont00001772 .

cco:ont00001773 a owl:DatatypeProperty ;
    rdfs:label "has integer value"@en ;
    skos:exactMatch cco:ont00001773 .

cco:ont00001841 a owl:ObjectProperty ;
    rdfs:label "is input of"@en ;
    skos:exactMatch cco:ont00001841 .

cco:ont00001857 a owl:ObjectProperty ;
    rdfs:label "is part of process"@en ;
    skos:exactMatch cco:ont00001857 .

cco:ont00001863 a owl:ObjectProperty ;
    rdfs:label "uses measurement unit"@en ;
    skos:exactMatch cco:ont00001863 .

cco:ont00001879 a owl:ObjectProperty ;
    rdfs:label "designated by"@en ;
    skos:exactMatch cco:ont00001879 .

cco:ont00001904 a owl:ObjectProperty ;
    rdfs:label "is measured by"@en ;
    skos:exactMatch cco:ont00001904 .

cco:ont00001916 a owl:ObjectProperty ;
    rdfs:label "designates"@en ;
    skos:exactMatch cco:ont00001916 .

cco:ont00001942 a owl:ObjectProperty ;
    rdfs:label "prescribes"@en ;
    skos:exactMatch cco:ont00001942 .

cco:ont00001953 a owl:ObjectProperty ;
    rdfs:label "has parent"@en ;
    skos:exactMatch cco:ont00001953 .

mds:BasketweaveMorphology a owl:Class ;
    rdfs:label "Basketweave Morphology"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        mds:GrainMorphology ;
    skos:altLabel "Basketweave Widmanstatten"@en ;
    skos:definition "A grain morphology in which alpha laths from multiple crystallographic variants interweave at various angles, forming a basket-like pattern. In Ti-6Al-4V, basketweave Widmanstatten alpha forms at isothermal hold temperatures of 700-870 C or continuous cooling rates above approximately 5 C/s (Whitney et al. 2024)."@en .

mds:BetaTitaniumSolutionization a owl:Class ;
    rdfs:label "Beta Titanium Solutionization"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom mds:XraySample ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        obo:BFO_0000015 ;
    skos:altLabel "β-Ti Solutionization"@en ;
    skos:definition "A heat treatment process where titanium alloy is heated above the beta transus temperature to convert the microstructure completely to the beta phase."@en .

mds:BimodalMorphology a owl:Class ;
    rdfs:label "Bimodal Morphology"@en ;
    rdfs:subClassOf mds:GrainMorphology ;
    skos:definition "A grain morphology consisting of a mixture of equiaxed primary alpha grains and lamellar alpha+beta regions, characteristic of wrought and annealed Ti-6Al-4V."@en .

mds:ColumnarMorphology a owl:Class ;
    rdfs:label "Columnar Morphology"@en ;
    rdfs:subClassOf mds:GrainMorphology ;
    skos:definition "A grain morphology in which grains are elongated along the direction of heat extraction, characteristic of directional solidification. In LPBF Ti-6Al-4V, prior beta grains are columnar along the build direction."@en .

mds:ContinuousCoolingTransformation a owl:Class ;
    rdfs:label "Continuous Cooling Transformation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom mds:XraySample ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( cco:DirectiveInformationContentEntity [ a owl:Restriction ;
                                owl:onProperty cco:ont00001808 ;
                                owl:someValuesFrom mds:CoolingRate ] ) ] ],
        obo:BFO_0000015 ;
    skos:definition "A heat treatment process where the material is cooled continuously at a controlled rate, allowing phase transformation during cooling."@en .

mds:CoolingSegment a owl:Class ;
    rdfs:label "Cooling Segment"@en ;
    rdfs:subClassOf mds:ThermalCycleSegment ;
    skos:definition "A segment of a thermal cycle during which temperature is decreased."@en .

mds:CrystalStructure a owl:Class ;
    rdfs:label "Crystal Structure"@en ;
    rdfs:subClassOf obo:BFO_0000019 .

mds:EquilibriumSolidification a owl:Class ;
    rdfs:label "Equilibrium Solidification"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:DiffusionalTransformation ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:EquiaxedMorphology ],
        mds:Solidification ;
    skos:definition "Solidification occurring at sufficiently slow cooling rates to approximate thermodynamic equilibrium, characteristic of conventional casting and wrought processing."@en .

mds:GrainBoundaryAlpha a owl:Class ;
    rdfs:label "Grain Boundary Alpha"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000171 ;
            owl:someValuesFrom mds:PriorBetaGrain ],
        mds:CrystallinePhase ;
    skos:altLabel "Allotriomorphic Alpha"@en ;
    skos:definition "A continuous or semi-continuous layer of alpha phase that forms along prior beta grain boundaries by a diffusional mechanism. It is the first alpha morphology to form on cooling below the beta transus in Ti-6Al-4V, and its volume fraction decreases with increasing cooling rate, vanishing at approximately 10 C/s (Whitney et al. 2024)."@en .

mds:HeatingSegment a owl:Class ;
    rdfs:label "Heating Segment"@en ;
    rdfs:subClassOf mds:ThermalCycleSegment ;
    skos:definition "A segment of a thermal cycle during which temperature is increased."@en .

mds:HeterogeneousNucleation a owl:Class ;
    rdfs:label "Heterogeneous Nucleation"@en ;
    rdfs:subClassOf mds:Nucleation ;
    skos:definition "Nucleation that occurs preferentially at crystallographic defects such as grain boundaries, dislocations, or free surfaces, where the energy barrier for nucleation is reduced."@en .

mds:IsothermalHoldTemperature a owl:Class ;
    rdfs:label "Isothermal Hold Temperature"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001769 ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:decimal ;
                    owl:withRestrictions ( [ xsd:minInclusive 600.0 ] [ xsd:maxInclusive 1000.0 ] ) ] ],
        cco:ont00000441 ;
    skos:definition "The constant temperature maintained during an isothermal hold segment of heat treatment."@en .

mds:Metadata a owl:Class ;
    rdfs:subClassOf cco:ont00000853 .

mds:Microstrain a owl:Class ;
    rdfs:label "Lattice Microstrain"@en ;
    rdfs:subClassOf obo:BFO_0000019 .

mds:Nucleation a owl:Class ;
    rdfs:label "Nucleation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000062 ;
            owl:someValuesFrom mds:GrainGrowth ],
        obo:BFO_0000015 ;
    skos:definition "A process in which a new thermodynamically stable phase or grain forms within an existing phase, initiating a phase transformation or recrystallization."@en .

mds:PhaseTransformation a owl:Class ;
    rdfs:label "Phase Transformation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        obo:BFO_0000015 ;
    skos:definition "A process in which a material changes from one crystallographic phase to another."@en .

mds:ResultID a owl:Class ;
    rdfs:subClassOf cco:ont00000686 .

mds:Solidification a owl:Class ;
    rdfs:label "Solidification"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000062 ;
            owl:someValuesFrom mds:SolidStatePhaseTransformation ],
        obo:BFO_0000015 ;
    skos:definition "A process in which a material transitions from the liquid phase to the solid phase."@en .

mds:StressRelief a owl:Class ;
    rdfs:label "Stress Relief"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:Recovery ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:IntergranularResidualStress ],
        obo:BFO_0000015 ;
    skos:definition "A thermally activated process in which intergranular and macroscopic residual stresses are relaxed through localized plastic deformation and diffusion, without necessarily involving dislocation annihilation. In LPBF Ti-6Al-4V, stress relief initiates concurrently with recovery at approximately 770 K (497 C) (Brown et al. 2021)."@en .

mds:UnitCell a owl:Class ;
    rdfs:label "Unit Cell"@en ;
    rdfs:subClassOf obo:BFO_0000040 ;
    skos:definition "The smallest repeating unit of the crystal structure." .

mds:VanadiumSupersaturation a owl:Class ;
    rdfs:label "Vanadium Supersaturation"@en ;
    rdfs:subClassOf mds:Supersaturation ;
    skos:definition "The excess vanadium concentration retained in the alpha or alpha-prime phase beyond its equilibrium solubility. In as-built LPBF Ti-6Al-4V, vanadium supersaturation in alpha-prime results from the martensitic transformation, which is too rapid for diffusional V rejection. This supersaturation contracts the lattice parameters relative to equilibrium alpha."@en .

mds:WidmanstattenMorphology a owl:Class ;
    rdfs:label "Widmanstatten Morphology"@en ;
    rdfs:subClassOf mds:GrainMorphology ;
    skos:definition "A general morphological pattern of plate-like or lath-like precipitates forming with specific crystallographic orientation relationships to the parent phase. In Ti-6Al-4V, Widmanstatten alpha forms within prior beta grains and may be arranged as colony/packeted or basketweave, depending on undercooling."@en .

mds:inhibits a owl:ObjectProperty ;
    rdfs:label "inhibits"@en ;
    rdfs:comment "A non-BFO convenience property indicating that one process suppresses or reduces the likelihood of another process occurring. The inverse of has_increased_likelihood_of."@en ;
    rdfs:domain obo:BFO_0000015 ;
    rdfs:range obo:BFO_0000015 .

cco:ont00000077 a owl:Class ;
    rdfs:label "Code Identifier"@en ;
    skos:exactMatch cco:ont00000077 .

cco:ont00000192 a owl:Class ;
    rdfs:label "Facility"@en ;
    skos:exactMatch cco:ont00000192 .

cco:ont00000420 a owl:Class ;
    rdfs:label "Computer"@en ;
    skos:exactMatch cco:ont00000420 .

cco:ont00000649 a owl:Class ;
    rdfs:label "Non-Name Identifier"@en ;
    skos:exactMatch cco:ont00000649 .

cco:ont00000798 a owl:Class ;
    rdfs:label "Information Bearing Artifact"@en ;
    skos:exactMatch cco:ont00000798 .

cco:ont00000908 a owl:Class ;
    rdfs:label "Act of Artifact Processing"@en ;
    skos:exactMatch cco:ont00000908 .

cco:ont00001180 a owl:Class ;
    rdfs:label "Organization"@en ;
    skos:exactMatch cco:ont00001180 .

obo:BFO_0000016 a owl:Class ;
    rdfs:label "disposition"@en .

obo:BFO_0000196 a owl:ObjectProperty ;
    rdfs:label "bearer of"@en .

mds:AcicularMorphology a owl:Class ;
    rdfs:label "Acicular Morphology"@en ;
    rdfs:subClassOf mds:GrainMorphology ;
    skos:altLabel "Needle-like Morphology"@en ;
    skos:definition "A grain morphology characterized by fine, needle-like features, typically associated with martensitic or Widmanstatten microstructures."@en .

mds:AdditiveManufacturingProcess a owl:Class ;
    rdfs:label "Additive Manufacturing Process"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:RapidSolidification ],
        mds:ProcessingMethod ;
    skos:altLabel "AM Process"@en ;
    skos:definition "A manufacturing process that produces components by selective fusion of feedstock material on demand to build a specified geometry layer by layer, typically resulting in rapid solidification and quenching of deposited material."@en .

mds:AlphaPrimeTiPhase a owl:Class ;
    rdfs:label "Alpha-Prime Titanium Phase"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000196 ;
            owl:someValuesFrom mds:VanadiumSupersaturation ],
        [ a owl:Restriction ;
            owl:onProperty mds:transforms_into ;
            owl:someValuesFrom mds:BetaTiPhase ],
        mds:CrystallinePhase ;
    skos:altLabel "Martensite (Ti)"@en,
        "a'-Ti"@en ;
    skos:definition "A metastable hexagonal close-packed phase of titanium alloy formed by martensitic transformation from the beta phase during rapid cooling. Alpha-prime has the same HCP crystal structure as equilibrium alpha but with a distorted unit cell due to supersaturated vanadium content that contracts the crystal lattice. It cannot be distinguished from equilibrium alpha by powder diffraction alone; the distinguishing feature is the presence of a transformation habit plane."@en .

mds:AlphaTiPhase a owl:Class ;
    rdfs:label "Alpha-Titanium Phase (HCP)"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000171 ;
            owl:someValuesFrom mds:AlphaTiUnitCell ],
        [ a owl:Restriction ;
            owl:onProperty mds:transforms_into ;
            owl:someValuesFrom mds:BetaTiPhase ],
        mds:CrystallinePhase ;
    skos:altLabel "α-Ti"@en ;
    skos:definition "Hexagonal close-packed phase of titanium alloy."@en .

mds:BetaTiPhase a owl:Class ;
    rdfs:label "Beta-Titanium Phase (BCC)"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000171 ;
            owl:someValuesFrom mds:BetaTiUnitCell ],
        [ a owl:Restriction ;
            owl:onProperty mds:transforms_into ;
            owl:someValuesFrom mds:AlphaTiPhase ],
        [ a owl:Restriction ;
            owl:onProperty mds:transforms_into ;
            owl:someValuesFrom mds:AlphaPrimeTiPhase ],
        mds:CrystallinePhase ;
    skos:altLabel "β-Ti"@en ;
    skos:definition "Body-centered cubic phase of titanium alloy."@en .

mds:ChemicalStrain a owl:Class ;
    rdfs:label "Chemical Strain"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A quality representing the component of lattice strain attributable to changes in solute chemistry rather than temperature or mechanical load. In Ti-6Al-4V, chemical strain in the beta phase arises primarily from changes in vanadium concentration and is quantified by subtracting the thermal expansion contribution from the total observed lattice strain (Brown et al. 2021)."@en .

mds:Concentration a owl:Class ;
    rdfs:label "Chemical Concentration"@en ;
    rdfs:subClassOf obo:BFO_0000019 .

mds:CoolingRate a owl:Class ;
    rdfs:label "Cooling Rate"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( mds:CoolingSegment mds:ContinuousCoolingTransformation ) ] ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001769 ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:decimal ;
                    owl:withRestrictions ( [ xsd:minExclusive 0.0 ] ) ] ],
        obo:BFO_0000144 ;
    skos:definition "The rate at which temperature decreases during cooling."@en .

mds:DislocationDensity a owl:Class ;
    rdfs:label "Dislocation Density"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A quality representing the total length of dislocation lines per unit volume of a crystalline material, typically expressed in m/m^3 or m^-2. In as-built LPBF Ti-6Al-4V, dislocation density is approximately 4.0 +/- 0.5 x 10^15 m^-2 (Brown et al. 2021)."@en .

mds:GrainGrowth a owl:Class ;
    rdfs:label "Grain Growth"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        obo:BFO_0000015 ;
    skos:definition "A process in which the average grain size of a polycrystalline material increases through the migration of grain boundaries driven by curvature reduction."@en .

mds:IntergranularResidualStress a owl:Class ;
    rdfs:label "Intergranular Residual Stress"@en ;
    rdfs:subClassOf mds:ResidualStressState ;
    skos:definition "A component of residual stress arising from the anisotropic response of differently oriented grains to plastic deformation or thermal gradients. Manifests as crystallographic-orientation-dependent interplanar spacing variations measurable by diffraction. In as-built LPBF Ti-6Al-4V, intergranular residual stresses develop during rapid cooling from solidification and anneal concurrently with recovery above 770 K (Brown et al. 2021)."@en .

mds:LamellarMorphology a owl:Class ;
    rdfs:label "Lamellar Morphology"@en ;
    rdfs:subClassOf mds:GrainMorphology ;
    skos:definition "A grain morphology consisting of alternating plates or lamellae of different phases, characteristic of colony alpha+beta microstructures formed by diffusional transformation."@en .

mds:MartensisiticTransformation a owl:Class ;
    rdfs:label "Martensitic Transformation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:AcicularMorphology ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:AlphaPrimeTiPhase ],
        mds:SolidStatePhaseTransformation ;
    skos:altLabel "Displacive Transformation"@en ;
    skos:definition "A displacive, diffusionless solid-state phase transformation characterized by a coordinated shear of the crystal lattice."@en .

mds:MillerIndices a owl:Class ;
    rdfs:label "Miller Indices (hkl)"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:definition "Crystallographic notation for crystal planes." .

mds:PhaseFraction a owl:Class ;
    rdfs:label "Phase Fraction"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The volumetric or mass proportion of a crystalline phase in a material." .

mds:ProcessingMethod a owl:Class ;
    rdfs:label "ProcessingMethod" ;
    rdfs:subClassOf cco:ont00000908 ;
    skos:definition "The manufacturing method by which the sample was created." .

mds:RapidSolidification a owl:Class ;
    rdfs:label "Rapid Solidification"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:MartensisiticTransformation ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ColumnarMorphology ],
        [ a owl:Restriction ;
            owl:onProperty mds:inhibits ;
            owl:someValuesFrom mds:DiffusionalTransformation ],
        [ a owl:Restriction ;
            owl:onProperty mds:inhibits ;
            owl:someValuesFrom mds:VanadiumPartitioning ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:DislocationDensity ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:IntergranularResidualStress ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:VanadiumSupersaturation ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:AcicularMorphology ],
        mds:Solidification ;
    skos:definition "Solidification occurring at high cooling rates, typically >10^3 K/s, characteristic of additive manufacturing processes such as LPBF, EBM, and LENS."@en .

mds:ResidualStressState a owl:Class ;
    rdfs:label "Residual Stress State"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A quality representing the self-equilibrating internal stresses remaining in a material after the removal of external loads or thermal gradients."@en .

mds:ThermalCycleSegment a owl:Class ;
    rdfs:label "Thermal Cycle Segment"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass obo:BFO_0000038 ;
            owl:onProperty obo:BFO_0000199 ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        obo:BFO_0000015 ;
    skos:definition "A distinct temporal segment or stage within a heat treatment thermal cycle."@en .

mds:VanadiumPartitioning a owl:Class ;
    rdfs:label "Vanadium Partitioning"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ChemicalStrain ],
        mds:SolutePartitioning ;
    skos:definition "The redistribution of vanadium between alpha and beta phases in Ti-6Al-4V driven by the thermodynamic preference of V for the beta phase. During heating, V diffuses from alpha to beta; during cooling, V is rejected from growing alpha grains into the remaining beta. The rate is controlled by bulk diffusion of V in the beta phase."@en .

cco:ont00000686 a owl:Class ;
    rdfs:label "Designative Information Content Entity"@en ;
    skos:exactMatch cco:ont00000686 .

obo:BFO_0000055 a owl:ObjectProperty ;
    rdfs:label "realized in"@en,
        "realizes"@en ;
    skos:exactMatch obo:BFO_0000055 .

obo:BFO_0000171 a owl:ObjectProperty ;
    rdfs:label "located in"@en ;
    skos:exactMatch obo:BFO_0000171 .

mds:CrystallinePhase a owl:Class ;
    rdfs:label "Crystalline Phase"@en ;
    rdfs:subClassOf obo:BFO_0000040 .

mds:DiffusionalTransformation a owl:Class ;
    rdfs:label "Diffusional Transformation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:LamellarMorphology ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:GrainBoundaryAlpha ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:AlphaTiPhase ],
        [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom mds:VanadiumPartitioning ],
        mds:SolidStatePhaseTransformation ;
    skos:altLabel "Diffusion-Controlled Transformation"@en ;
    skos:definition "A solid-state phase transformation driven by thermally activated diffusion of atoms across the transformation interface."@en .

mds:Recovery a owl:Class ;
    rdfs:label "Recovery"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000062 ;
            owl:someValuesFrom mds:Recrystallization ],
        [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:StressRelief ],
        [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000062 ;
            owl:someValuesFrom mds:SolidStatePhaseTransformation ],
        [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:Recrystallization ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:DislocationDensity ],
        obo:BFO_0000015 ;
    skos:definition "A thermally activated process in which stored strain energy is reduced through dislocation rearrangement and annihilation without the migration of high-angle grain boundaries."@en .

mds:Recrystallization a owl:Class ;
    rdfs:label "Recrystallization"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:EquiaxedMorphology ],
        obo:BFO_0000015 ;
    skos:definition "A process in which deformed grains are replaced by new, strain-free grains through the nucleation and growth of high-angle grain boundaries."@en .

mds:ThermalStrain a owl:Class ;
    rdfs:label "Thermal Strain"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A quality representing the component of lattice strain attributable solely to thermal expansion or contraction, calculated as alpha_CTE * delta_T."@en .

mds:transforms_into a owl:ObjectProperty ;
    rdfs:label "transforms into"@en ;
    rdfs:comment "Indicates that one crystalline phase or material entity undergoes transformation into another. Direction follows thermodynamic convention (e.g., beta to alpha on cooling for Ti-6Al-4V)."@en ;
    rdfs:domain obo:BFO_0000040 ;
    rdfs:range obo:BFO_0000040 .

cco:ont00000253 a owl:Class ;
    rdfs:label "Information Bearing Entity"@en ;
    skos:exactMatch cco:ont00000253 .

cco:ont00000292 a owl:Class ;
    rdfs:label "Artifact Identifier"@en ;
    skos:exactMatch cco:ont00000292 .

cco:ont00000345 a owl:Class ;
    rdfs:label "Act of Measuring"@en .

cco:ont00000441 a owl:Class ;
    rdfs:label "Temperature"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom obo:BFO_0000040 ] .

cco:ont00001158 a owl:Class ;
    rdfs:label "Act of Data Transformation"@en ;
    skos:exactMatch cco:ont00001158 .

mds:Beamline a owl:Class ;
    rdfs:label "Beamline" ;
    rdfs:subClassOf cco:ont00000192 ;
    skos:definition "Individual tangential sections in a synchrotron ring where experiments can be performed." .

mds:EquiaxedMorphology a owl:Class ;
    rdfs:label "Equiaxed Morphology"@en ;
    rdfs:subClassOf mds:GrainMorphology ;
    skos:definition "A grain morphology in which grains have approximately equal dimensions in all directions."@en .

mds:GoverningLaw a owl:Class ;
    rdfs:label "Governing Law"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:definition "An information content entity representing a physical or empirical law that prescribes a quantitative relationship between measurable qualities. The actual computation is performed externally; this entity records which quantities are governed."@en .

mds:LatticeParameter a owl:Class ;
    rdfs:label "Lattice Parameter"@en ;
    rdfs:subClassOf obo:BFO_0000019 .

mds:SynchrotronFacility a owl:Class ;
    rdfs:label "SynchrotronFacility" ;
    rdfs:subClassOf cco:ont00001180 ;
    skos:definition "A synchrotron facility that allows studying material properties using high energy X-rays." .

mds:XraySample a owl:Class ;
    rdfs:label "XraySample" ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:altLabel "Sample" ;
    skos:definition "A specimen used for X-ray based experiments." .

cco:ont00001921 a owl:ObjectProperty ;
    rdfs:label "has input"@en ;
    skos:exactMatch cco:ont00001921 .

obo:BFO_0000062 a owl:ObjectProperty ;
    rdfs:label "precedes"@en ;
    skos:definition "A temporal relation where one process ends before another begins."@en .

mds:IntegratedDiffractionPattern a owl:Class ;
    rdfs:label "1D pattern",
        "Azimuthally Integrated Pattern"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:definition " A one-dimensional intensity profile derived from the azimuthal integration of a two-dimensional diffraction pattern.",
        "1D diffraction pattern created by azimuthal integration of 2D detector data." .

mds:SolidStatePhaseTransformation a owl:Class ;
    rdfs:label "Solid State Phase Transformation"@en ;
    rdfs:subClassOf mds:PhaseTransformation ;
    skos:definition "A phase transformation that occurs entirely in the solid state, without melting."@en .

