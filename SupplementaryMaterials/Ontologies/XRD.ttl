@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix mds: <https://cwrusdle.bitbucket.io/files/MDS_Onto/index-en.html#https://cwrusdle.bitbucket.io/mds/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mds: a owl:Ontology ;
    rdfs:label "MDS Neural Network Modeling Ontology"@en ;
    rdfs:comment "An ontology for neural network modeling and training processes based on Common Core Ontology"@en ;
    owl:imports <http://www.ontologyrepository.com/CommonCoreOntologies/> .

mds:APS_1ID a owl:Class ;
    rdfs:label "APS 1-ID Beamline" ;
    rdfs:subClassOf mds:Beamline ;
    skos:definition "The 1-ID beamline at the Advanced Photon Source, specialized for high-energy X-ray diffraction and imaging." .

mds:APS_5ID a owl:Class ;
    rdfs:label "APS 5-ID Beamline" ;
    rdfs:subClassOf mds:Beamline ;
    skos:definition "The 5-ID beamline at the Advanced Photon Source, designed for dynamic compression experiments." .

mds:AlphaLathWidth a owl:Class ;
    rdfs:label "Alpha Lath Width"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        obo:BFO_0000019 ;
    skos:definition "The in-plane width of individual alpha-phase laths, a key microstructural length scale that decreases with lower isothermal hold temperature and greater continuous cooling rate. In as-built LPBF Ti-6Al-4V, the average lath width is approximately 2 micrometers, increasing with heat treatment temperature (Brown et al. 2021)."@en .

mds:AlphaMicrostrain a owl:Class ;
    rdfs:label "Alpha Phase Microstrain"@en ;
    rdfs:subClassOf mds:Microstrain .

mds:AlphaPhaseAspectRatio a owl:Class ;
    rdfs:label "Alpha Phase Aspect Ratio"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The ratio of length to width of alpha-phase laths or grains, which increases with increasing cooling rate in Ti-6Al-4V."@en .

mds:BetaMicrostrain a owl:Class ;
    rdfs:label "Beta Phase Microstrain"@en ;
    rdfs:subClassOf mds:Microstrain .

mds:BetaTitaniumTransusTemperature a owl:Class ;
    rdfs:label "Beta Titanium Transus Temperature"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001769 ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:decimal ;
                    owl:withRestrictions ( [ xsd:minInclusive 975.0 ] [ xsd:maxInclusive 1005.0 ] ) ] ],
        mds:TransusTemperature ;
    skos:altLabel "β-Ti Transus Temperature"@en ;
    skos:definition "The temperature above which titanium alloy exists entirely as beta phase, typically around 980°C for Ti-6Al-4V."@en .

mds:CHESS_F2 a owl:Class ;
    rdfs:label "CHESS F2 Beamline" ;
    rdfs:subClassOf mds:Beamline ;
    skos:definition "The F2 beamline at CHESS, optimized for high-energy X-ray scattering." .

mds:CHESS_FAST a owl:Class ;
    rdfs:label "CHESS FAST Beamline" ;
    rdfs:subClassOf mds:Beamline ;
    skos:definition "The FAST beamline at CHESS, designed for rapid data collection." .

mds:CarbonFilter a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A carbon-based filter positioned upstream of the monochromator to attenuate or condition the X-ray beam." .

mds:CarbonFilterPosition a owl:Class ;
    rdfs:label "Carbon filter position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "cfilt" ;
    skos:definition "The positioning of a carbon filter along the beamline axis." .

mds:ConcentrationContent a owl:Class ;
    rdfs:label "Concentration Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:CrystalliteSize a owl:Class ;
    rdfs:label "Crystallite Size"@en ;
    rdfs:subClassOf cco:ont00000738 .

mds:CrystalliteSizeContent a owl:Class ;
    rdfs:label "Crystallite Size Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:CrystallographicIBE a owl:Class ;
    rdfs:label "Crystallographic Value Bearer"@en ;
    rdfs:subClassOf cco:ont00000253 ;
    skos:definition "Entity that bears numerical crystallographic measurement values." .

mds:DefectConcentration a owl:Class ;
    rdfs:label "Defect Concentration"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "A quality representing the density of crystallographic point defects (vacancies, interstitials) in a material."@en .

mds:DetectorCalibration a owl:Class ;
    rdfs:subClassOf obo:BFO_0000015 ;
    skos:definition "A process for adjusting and standardizing detector response to ensure accurate X-ray measurements." .

mds:DiffractionPeak a owl:Class ;
    rdfs:label "Diffraction Peak"@en ;
    rdfs:subClassOf obo:BFO_0000141 ;
    skos:definition "A feature in the diffraction pattern corresponding to a specific crystal plane reflection." .

mds:EnergyCalibrationFoil a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A thin metallic foil used to calibrate X-ray energy measurements by providing known absorption edges." .

mds:EnergyCalibrationFoilXPosition a owl:Class ;
    rdfs:label "Calibration foil x-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "foilx" ;
    skos:definition "The site that is the positioning of an energy calibration foil along the X-axis in the laboratory coordinate system." .

mds:EnergyCalibrationFoilZPosition a owl:Class ;
    rdfs:label "Calibration foil z-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "foilz" ;
    skos:definition "The site that is the positioning of an energy calibration foil along the Z-axis in the laboratory coordinate system." .

mds:EpitaxialNucleation a owl:Class ;
    rdfs:label "Epitaxial Nucleation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000063 ;
            owl:someValuesFrom mds:DiffusionalTransformation ],
        mds:HeterogeneousNucleation ;
    skos:definition "Nucleation of a new phase that grows coherently from an existing phase boundary, inheriting the crystallographic orientation relationship. In Ti-6Al-4V, Widmanstatten alpha laths nucleate epitaxially from grain boundary alpha (Whitney et al. 2024)."@en .

mds:GPUComputeSystem a owl:Class ;
    rdfs:label "GPU Compute System"@en ;
    rdfs:comment "A computational hardware system utilizing graphics processing units for neural network training."@en ;
    rdfs:subClassOf mds:ComputationalHardwareSystem .

mds:GrainCoarsening a owl:Class ;
    rdfs:label "Grain Coarsening"@en ;
    rdfs:subClassOf mds:GrainGrowth ;
    skos:altLabel "Abnormal Grain Growth"@en ;
    skos:definition "Abnormal or exaggerated grain growth in which a subset of grains grows preferentially at the expense of neighboring grains."@en .

mds:HeatingRate a owl:Class ;
    rdfs:label "Heating Rate"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( mds:HeatingSegment mds:BetaTitaniumSolutionization ) ] ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001769 ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:decimal ;
                    owl:withRestrictions ( [ xsd:minExclusive 0.0 ] ) ] ],
        obo:BFO_0000144 ;
    skos:definition "The rate at which temperature increases during heating."@en .

mds:InterplanarSpacingContent a owl:Class ;
    rdfs:label "Interplanar Spacing Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:LatticeParameterA a owl:Class ;
    rdfs:label "Lattice Parameter a"@en ;
    rdfs:subClassOf mds:LatticeParameter .

mds:LatticeParameterC a owl:Class ;
    rdfs:label "Lattice Parameter c"@en ;
    rdfs:subClassOf mds:LatticeParameter .

mds:LatticeParameterContent a owl:Class ;
    rdfs:label "Lattice Parameter Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:MicrostrainContent a owl:Class ;
    rdfs:label "Microstrain Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:ModelObject a owl:Class ;
    rdfs:label "The trained model object file, whatever the format."@en ;
    rdfs:subClassOf cco:ont00000798 .

mds:ModelPerformanceMetric a owl:Class ;
    rdfs:label "Model Performance Metric"@en ;
    rdfs:comment "A measurement information content entity that quantifies neural network model performance."@en ;
    rdfs:subClassOf cco:ont00001163 .

mds:MonochromatorRotationValue cco:ont00001769 -69.0 ;
    cco:ont00001863 qudt:RAD .

mds:NeuralNetworkModelSpecification a owl:Class ;
    rdfs:label "Neural Network Model Specification"@en ;
    rdfs:comment "An algorithmic entity that prescribes how a neural network processes inputs to produce outputs."@en ;
    rdfs:subClassOf cco:ont00000653 .

mds:NumberOfPointsAzimuthValue cco:ont00001773 -69 .

mds:OpenCLDevice a owl:Class ;
    rdfs:label "OpenCLDevice" ;
    rdfs:subClassOf cco:ont00000420 ;
    skos:altLabel "opencl_device" ;
    skos:definition "The computing device used for processing of the integration process." .

mds:OpticalTableJackHorizontalPosition1 a owl:Class ;
    rdfs:label "Optical table jack horizontal position 1" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "x1" ;
    skos:definition "An alternate horizontal positioning measurement of an optical table jack." .

mds:OpticalTableJackRightTransversePosition a owl:Class ;
    rdfs:label "Optical table jack right transverse position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "yr" ;
    skos:definition "The transverse positioning measurement of the right-side optical table jack." .

mds:OpticalTableJackTransversePosition1 a owl:Class ;
    rdfs:label "Optical table jack transverse position 1" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "y1" ;
    skos:definition "An alternate transverse positioning measurement of an optical table jack." .

mds:OpticalTableVerticalPosition a owl:Class ;
    rdfs:label "Optical table vertical position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "tzt" ;
    skos:definition "The vertical positioning of an optical table parallel to the gravitational axis." .

mds:PeakIntensity a owl:Class ;
    rdfs:label "Peak Intensity"@en ;
    rdfs:subClassOf obo:BFO_0000019 .

mds:PeakIntensityContent a owl:Class ;
    rdfs:label "Peak Intensity Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:PeakPositionContent a owl:Class ;
    rdfs:label "Peak Position Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:PriorBetaGrainSize a owl:Class ;
    rdfs:label "Prior Beta Grain Size"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The average size of prior beta grains as measured in the plane normal to their elongation direction. In LPBF Ti-6Al-4V, prior beta grains are columnar along the build direction with average diameters of approximately 84 micrometers in the XY plane (Whitney et al. 2024)."@en .

mds:RecipeID a owl:Class ;
    rdfs:subClassOf cco:ont00000649 .

mds:RietveldRefinement a owl:Class ;
    rdfs:label "Rietveld Refinement"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001921 ;
            owl:someValuesFrom mds:IntegratedDiffractionPattern ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:PhaseFraction ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:LatticeParameter ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:CrystallographicTexture ],
        cco:ont00000345 ;
    skos:definition "Least-squares fitting of calculated to observed diffraction patterns." .

mds:RwpContent a owl:Class ;
    rdfs:label "Rwp Information Content"@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:SafetyBrickHorizontalPosition a owl:Class ;
    rdfs:label "Safety brick horizontal position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "safety_brick" ;
    skos:definition "The horizontal positioning of a safety brick assembly along the beamline axis." .

mds:SampleAlignment a owl:Class ;
    rdfs:subClassOf obo:BFO_0000015 ;
    skos:definition "A process for positioning and orienting an X-ray sample to achieve optimal beam interaction and measurement conditions." .

mds:TestDataRole a owl:Class ;
    rdfs:label "Test Data Role"@en ;
    rdfs:comment "A role inhering in data that is used to test a trained neural network."@en ;
    rdfs:subClassOf obo:0000023 .

mds:Tool_1 obo:BFO_0000056 mds:XrayRecipe_1 .

mds:Training a owl:Class ;
    rdfs:label "Training" ;
    rdfs:subClassOf obo:BFO_0000015 .

mds:TrainingDataRole a owl:Class ;
    rdfs:label "Training Data Role"@en ;
    rdfs:comment "A role inhering in data that is used to train a neural network."@en ;
    rdfs:subClassOf obo:0000023 .

mds:Undercooling a owl:Class ;
    rdfs:label "Undercooling"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "Supercooling"@en ;
    skos:definition "A quality representing the difference between the equilibrium transformation temperature and the actual temperature at which a transformation occurs. Greater undercooling increases the thermodynamic driving force for transformation and influences the transformation mechanism and resulting morphology."@en .

mds:ValidationDataRole a owl:Class ;
    rdfs:label "Validation Data Role"@en ;
    rdfs:comment "A role inhering in data that is used to validate a neural network during training."@en ;
    rdfs:subClassOf obo:0000023 .

mds:VanadiumConcentration a owl:Class ;
    rdfs:label "Vanadium Concentration (Atomic %)"@en ;
    rdfs:subClassOf mds:Concentration .

mds:WeightedProfileRFactor a owl:Class ;
    rdfs:label "Weighted Profile R-Factor (Rwp)"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "Goodness-of-fit metric for Rietveld refinement." .

mds:XrayResult a owl:Class .

mds:h_index a owl:DatatypeProperty ;
    rdfs:label "h index"@en ;
    rdfs:domain mds:MillerIndices ;
    rdfs:range xsd:integer .

mds:k_index a owl:DatatypeProperty ;
    rdfs:label "k index"@en ;
    rdfs:domain mds:MillerIndices ;
    rdfs:range xsd:integer .

mds:l_index a owl:DatatypeProperty ;
    rdfs:label "l index"@en ;
    rdfs:domain mds:MillerIndices ;
    rdfs:range xsd:integer .

obo:BFO_0000056 a owl:ObjectProperty ;
    rdfs:label "participates in"@en ;
    skos:exactMatch obo:BFO_0000056 .

obo:BFO_0000063 a owl:ObjectProperty ;
    rdfs:label "preceded by"@en ;
    owl:inverseOf obo:BFO_0000062 ;
    skos:definition "A temporal relation where one process begins after another ends."@en .

obo:BFO_0000084 a owl:ObjectProperty ;
    rdfs:label "generically depends on"@en ;
    skos:exactMatch obo:BFO_0000084 .

obo:BFO_0000141 a owl:Class ;
    rdfs:label "immaterial entity"@en .

mds:APS a owl:Class ;
    rdfs:label "Advanced Photon Source" ;
    rdfs:subClassOf mds:SynchrotronFacility ;
    skos:definition "The Advanced Photon Source at Argonne National Laboratory." .

mds:AlphaTiUnitCell a owl:Class ;
    rdfs:label "Alpha-Ti Unit Cell"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000196 ;
            owl:someValuesFrom mds:HexagonalClosePacked ],
        mds:UnitCell .

mds:AndorNeo a owl:Class ;
    rdfs:label "DC-152Q-C00-F1 (Andor Neo)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:AsFastAsPossibleCooling a owl:Class ;
    rdfs:label "As Fast As Possible Cooling"@en ;
    rdfs:subClassOf mds:CoolingRate ;
    skos:altLabel "AFAP Cooling"@en ;
    skos:definition "A cooling rate achieved by removing all active heating and allowing natural heat dissipation, typically resulting in variable cooling rates."@en .

mds:AttenuatorWheels a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A rotating wheel assembly containing multiple filter materials of varying thicknesses to attenuate X-ray beam intensity." .

mds:AttenuatorWheelsPosition a owl:Class ;
    rdfs:label "Attenuator wheel position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "att",
        "attf" ;
    skos:definition "The rotational positioning of attenuator wheels to select different filter materials or thicknesses." .

mds:AvramiEquation a owl:Class ;
    rdfs:label "Avrami Equation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:PhaseFraction ],
        mds:GoverningLaw ;
    skos:altLabel "JMAK Equation"@en ;
    skos:definition "The Johnson-Mehl-Avrami-Kolmogorov equation describing the kinetics of phase transformation: f(t) = 1 - exp(-k*t^n), where f is transformed fraction, t is time, k is rate constant, and n is Avrami exponent."@en .

mds:AzimuthalIntegration a owl:Class ;
    rdfs:label "Integration",
        "Azimuthal Integration"@en ;
    rdfs:subClassOf cco:ont00000006,
        cco:ont00001158 ;
    skos:definition "A computational process class that performs the transformation of two-dimensional diffraction data into one-dimensional patterns by integrating intensity values along azimuthal angles at constant radial distances from the beam center.",
        "Process of reducing 2D diffraction to 1D pattern by radial integration." .

mds:AzimuthalRange a owl:Class ;
    rdfs:label "AzimuthalRange" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "azimuth_range" ;
    skos:definition "The angular range in azimuthal direction to include in the integration." .

mds:BackpropagationProcess a owl:Class ;
    rdfs:label "Backpropagation Process"@en ;
    rdfs:comment "A process of computing gradients and updating neural network weights."@en ;
    rdfs:subClassOf cco:ActOfAlgorithmicProcessing .

mds:BatchSizeSpecification a owl:Class ;
    rdfs:label "Batch Size Specification"@en ;
    rdfs:comment "An information content entity that specifies the number of samples processed before model update."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:BeamConvergence a owl:Class ;
    rdfs:label "BeamConvergence" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The convergence of the incoming X-ray beam." .

mds:BeamStop a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A dense material component designed to absorb X-ray beams and protect downstream equipment in synchrotron beamlines." .

mds:BeamStopRotation a owl:Class ;
    rdfs:label "beam stop rotation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "bsr" ;
    skos:definition "The rotational positioning capability of a beamstop around one or more axes." .

mds:BeamStopTransversePosition a owl:Class ;
    rdfs:label "Beam stop x-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "bsx" ;
    skos:definition "The horizontal positioning of a beamstop perpendicular to the beam direction." .

mds:BeamStopVerticalPosition a owl:Class ;
    rdfs:label "beam stop z-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "bsz" ;
    skos:definition "The vertical positioning of a beamstop parallel to the gravitational axis." .

mds:BetaTiUnitCell a owl:Class ;
    rdfs:label "Beta-Ti Unit Cell"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000196 ;
            owl:someValuesFrom mds:BodyCenteredCubic ],
        mds:UnitCell .

mds:BitDepth a owl:Class ;
    rdfs:label "Bit Depth" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "Bit depth of the detector." .

mds:BodyCenteredCubic a owl:Class ;
    rdfs:label "Body Centered Cubic (BCC)"@en ;
    rdfs:subClassOf mds:CrystalStructure .

mds:BottomCaveSlitPosition a owl:Class ;
    rdfs:label "Bottom cave slit" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "cslitb" ;
    skos:definition "The positioning of the lower blade of a cave slit to control the vertical beam aperture from below." .

mds:BraggsLaw a owl:Class ;
    rdfs:label "Bragg's Law"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:BeamWavelength ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:InterplanarSpacing ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:PeakPosition2Theta ],
        mds:GoverningLaw ;
    skos:definition "The law relating X-ray wavelength, interplanar spacing, and diffraction angle: n*lambda = 2*d*sin(theta)."@en .

mds:CCTDiagram a owl:Class ;
    rdfs:label "Continuous Cooling Transformation Diagram"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:altLabel "CCT Diagram"@en ;
    skos:definition "An information content entity representing phase transformation behavior under continuous cooling conditions by plotting transformation start and end loci as functions of cooling rate and temperature."@en .

mds:CHESS a owl:Class ;
    rdfs:label "Cornell High Energy Synchrotron Source" ;
    rdfs:subClassOf mds:SynchrotronFacility ;
    skos:definition "Cornell High Energy Synchrotron Source at Cornell University." .

mds:CaveSlit a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A precision aperture device that defines and controls the cross-sectional area of an X-ray beam in a beamline hutch or cave." .

mds:ChemicalFormula a owl:Class ;
    rdfs:label "ChemicalFormula" ;
    rdfs:subClassOf cco:ont00000686 ;
    skos:definition "Chemical composition of the material." .

mds:ChiDiscontinuity a owl:Class ;
    rdfs:label "ChiDiscontinuity" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "chi_discontinuity" ;
    skos:definition "The position of the discontinuity of the chi axis between 0 and 2π." .

mds:CoefficientOfThermalExpansion a owl:Class ;
    rdfs:label "Coefficient of Thermal Expansion"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "CTE"@en ;
    skos:definition "A quality representing the fractional change in lattice parameter or interplanar spacing per unit temperature change. May be crystallographic-orientation-dependent in non-cubic phases. In Ti-6Al-4V, the average alpha-phase CTE is approximately 9.7 x 10^-6 /K on heating and 11.2 x 10^-6 /K on cooling; the beta-phase CTE is approximately 9.3-9.5 x 10^-6 /K (Brown et al. 2021)."@en .

mds:CoherentScatteringDomainSize a owl:Class ;
    rdfs:label "Coherent Scattering Domain Size"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "Sub-grain Size"@en ;
    skos:definition "The area-weighted average size of crystallographic domains that scatter X-rays coherently, determined from diffraction line profile analysis (DLPA). It represents the sub-grain size and is approximately 23 +/- 3 nm in as-built LPBF Ti-6Al-4V (Brown et al. 2021)."@en .

mds:ColonyMorphology a owl:Class ;
    rdfs:label "Colony Morphology"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000197 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        mds:LamellarMorphology ;
    skos:altLabel "Packeted Morphology"@en ;
    skos:definition "A morphology in which groups of parallel alpha laths of the same crystallographic variant form colonies within a prior beta grain. In Ti-6Al-4V, colony (packeted) Widmanstatten alpha forms at isothermal transformation temperatures of 870-950 C or at continuous cooling rates below approximately 5 C/s (Whitney et al. 2024)."@en .

mds:ComputationalHardwareSystem a owl:Class ;
    rdfs:label "Computational Hardware System"@en ;
    rdfs:comment "An artifact that provides computational resources for neural network training."@en ;
    rdfs:subClassOf cco:Artifact .

mds:ControlledCoolingRate a owl:Class ;
    rdfs:label "Controlled Cooling Rate"@en ;
    rdfs:subClassOf mds:CoolingRate ;
    skos:definition "A cooling rate that is actively controlled to maintain a specific value."@en .

mds:CrystallographicTexture a owl:Class ;
    rdfs:label "Crystallographic Texture"@en ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "Preferred Orientation"@en ;
    skos:definition "A quality representing the statistical distribution of crystallographic orientations in a polycrystalline material. Described quantitatively by the Orientation Distribution Function (ODF) and represented visually by pole figures."@en .

mds:DXR250RTPlus a owl:Class ;
    rdfs:label "2304871 (DXR-250RT+)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:DarkCorrection a owl:Class ;
    rdfs:label "DarkCorrection" ;
    rdfs:subClassOf cco:ont00001158 ;
    skos:definition "A  calibration procedure where an offset map is subtracted from X-ray exposures." .

mds:DataPreprocessingOutput a owl:Class ;
    rdfs:label "Data Preprocessing Output"@en ;
    rdfs:comment "An information content entity that is the output of the SyncXrayPreProcessing process and serves as input to modeling."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:DetectorLength a owl:Class ;
    rdfs:label "Detector Length" ;
    rdfs:subClassOf cco:ont00000738 ;
    skos:definition "The length of the detector." .

mds:DetectorManufacturer a owl:Class ;
    rdfs:label "Detector Manufacturer" ;
    rdfs:subClassOf cco:Organization ;
    skos:definition "An organization that manufactures detectors." .

mds:DetectorManufacturing a owl:Class ;
    rdfs:label "Detector Manufacturing" ;
    rdfs:subClassOf cco:ont00001359 ;
    skos:definition "A manufacturing process that produces detectors." .

mds:DetectorName a owl:Class ;
    rdfs:label "Detector Name" ;
    rdfs:subClassOf cco:ont00000292 ;
    skos:definition "Name of the detector." .

mds:DetectorWidth a owl:Class ;
    rdfs:label "Detector Width" ;
    rdfs:subClassOf cco:ont00000738 ;
    skos:definition "The width of the detector." .

mds:DetectorXOrientation a owl:Class ;
    rdfs:label "Detector x-orientation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "detxr" ;
    skos:definition "The angular orientation of a detector around the X-axis in the laboratory coordinate system." .

mds:DetectorXPosition a owl:Class ;
    rdfs:label "Detector x-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "detx" ;
    skos:definition "The positioning of a detector along the X-axis in the laboratory coordinate system." .

mds:DetectorYOrientation a owl:Class ;
    rdfs:label "Detector y-orientation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "detyr" ;
    skos:definition "The angular orientation of a detector around the Y-axis in the laboratory coordinate system." .

mds:DetectorYPosition a owl:Class ;
    rdfs:label "Detector y-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "dety" ;
    skos:definition "The positioning of a detector along the Y-axis in the laboratory coordinate system." .

mds:DetectorZOrientation a owl:Class ;
    rdfs:label "Detector z-orientation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "detzr" ;
    skos:definition "The angular orientation of a detector around the Z-axis in the laboratory coordinate system." .

mds:DetectorZPosition a owl:Class ;
    rdfs:label "Detector z-position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "detz" ;
    skos:definition "The positioning of a detector along the Z-axis, typically controlling the sample-to-detector distance." .

mds:Dexela2923 a owl:Class ;
    rdfs:label "Dexela 2923" ;
    rdfs:subClassOf mds:XrayDetector .

mds:DiffractionLineProfileAnalysis a owl:Class ;
    rdfs:label "Diffraction Line Profile Analysis"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001921 ;
            owl:someValuesFrom mds:IntegratedDiffractionPattern ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:DislocationDensity ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:CoherentScatteringDomainSize ],
        cco:ont00000345 ;
    skos:altLabel "DLPA"@en ;
    skos:definition "A quantitative analysis method that extracts microstructural information (dislocation density, sub-grain size, dislocation character) from the shape and breadth of diffraction peaks using convolutional methods such as eCMWP."@en .

mds:DiffusionalDisplaciveTransformation a owl:Class ;
    rdfs:label "Diffusional-Displacive Transformation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:WidmanstattenMorphology ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:BasketweaveMorphology ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:ColonyMorphology ],
        [ a owl:Restriction ;
            owl:onProperty mds:has_decoupled_kinetics_from ;
            owl:someValuesFrom mds:VanadiumPartitioning ],
        mds:SolidStatePhaseTransformation ;
    skos:altLabel "Mixed-Mode Transformation"@en ;
    skos:definition "A mixed solid-state phase transformation mechanism involving thermally activated nucleation of alpha lath subunits followed by displacive (shear) growth. The structural transformation proceeds faster than solute redistribution, indicating that diffusional processes alone are not responsible. Observed in Ti-6Al-4V at isothermal hold temperatures below approximately 865 C and at all continuous cooling rates studied (Whitney et al. 2024)."@en .

mds:DirectedEnergyDeposition a owl:Class ;
    rdfs:label "Directed Energy Deposition"@en ;
    rdfs:subClassOf mds:AdditiveManufacturingProcess ;
    skos:altLabel "DED"@en,
        "LENS"@en ;
    skos:definition "An additive manufacturing process in which focused thermal energy is used to fuse material as it is deposited, encompassing wire-fed and powder-fed variants such as LENS."@en .

mds:DislocationAnnihilation a owl:Class ;
    rdfs:label "Dislocation Annihilation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000062 ;
            owl:someValuesFrom mds:Recovery ],
        obo:BFO_0000015 ;
    skos:definition "A process in which dislocations of opposite sign interact and cancel, reducing the total dislocation density."@en .

mds:DislocationMultiplication a owl:Class ;
    rdfs:label "Dislocation Multiplication"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom obo:BFO_0000040 ],
        [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:Recovery ],
        obo:BFO_0000015 ;
    skos:definition "A process in which the dislocation density increases through mechanisms such as Frank-Read source operation during plastic deformation."@en .

mds:Eiger1M a owl:Class ;
    rdfs:label "Eiger 1M" ;
    rdfs:subClassOf mds:XrayDetector .

mds:ElectronBeamMelting a owl:Class ;
    rdfs:label "Electron Beam Melting"@en ;
    rdfs:subClassOf mds:AdditiveManufacturingProcess ;
    skos:altLabel "EBM"@en ;
    skos:definition "An additive manufacturing process using a focused electron beam to selectively melt powder feedstock under vacuum conditions."@en .

mds:EnergyRange a owl:Class ;
    rdfs:label "EnergyRange" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The energy range the particular beamline can cover." .

mds:EpochCountSpecification a owl:Class ;
    rdfs:label "Epoch Count Specification"@en ;
    rdfs:comment "An information content entity that specifies the number of complete passes through the training dataset."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:EquilibriumPhaseDiagram a owl:Class ;
    rdfs:label "Equilibrium Phase Diagram"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:definition "An information content entity representing the thermodynamically stable phase fields of a material system as a function of temperature and composition."@en .

mds:ErrorModel a owl:Class ;
    rdfs:label "Error model" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "error_model" ;
    skos:definition "Statistical model used for error propagation during integration." .

mds:HardenabilityDisposition a owl:Class ;
    rdfs:label "Hardenability Disposition"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000055 ;
            owl:someValuesFrom mds:MartensisiticTransformation ],
        obo:BFO_0000016 ;
    skos:definition "A disposition of a material to form martensite during cooling, reflecting the ease with which diffusionless transformation occurs."@en .

mds:HexagonalClosePacked a owl:Class ;
    rdfs:label "Hexagonal Close Packed (HCP)"@en ;
    rdfs:subClassOf mds:CrystalStructure .

mds:HoldSegment a owl:Class ;
    rdfs:label "Hold Segment"@en ;
    rdfs:subClassOf mds:ThermalCycleSegment ;
    skos:altLabel "Isothermal Hold Segment"@en,
        "Soaking Segment"@en ;
    skos:definition "A segment of a thermal cycle during which temperature is maintained constant."@en .

mds:HomogeneousNucleation a owl:Class ;
    rdfs:label "Homogeneous Nucleation"@en ;
    rdfs:subClassOf mds:Nucleation ;
    skos:definition "Nucleation that occurs uniformly throughout the bulk of the parent phase without preferential formation at crystallographic defects."@en .

mds:HorizontalCaveSlitPosition a owl:Class ;
    rdfs:label "Horizontal cave slit position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "cslitx" ;
    skos:definition "The horizontal positioning of cave slit blades to control the lateral beam aperture." .

mds:HorizontalCaveSlitWidth a owl:Class ;
    rdfs:label "Horizontal cave slit width" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "cslitw" ;
    skos:definition "The width measurement of the horizontal aperture opening created by the cave slit blades." .

mds:HuberSampleStage a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A precision positioning system manufactured by Huber that provides fine sample positioning and rotation capabilities." .

mds:HuberStageHorizontalPosition a owl:Class ;
    rdfs:label "Huber stage horizontal position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "huberx" ;
    skos:definition "The horizontal positioning of a Huber sample stage perpendicular to the beam direction." .

mds:HuberStageRotation a owl:Class ;
    rdfs:label "Huber stage rotation" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "hubero" ;
    skos:definition "The rotational positioning of a Huber sample stage around its central axis." .

mds:HuberStageTransversePosition a owl:Class ;
    rdfs:label "Huber stage transverse position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "hubery" ;
    skos:definition "The positioning of a Huber sample stage along the beam direction axis." .

mds:HyperparameterConfiguration a owl:Class ;
    rdfs:label "Hyperparameter Configuration"@en ;
    rdfs:comment "An information content entity that specifies the hyperparameters for neural network training."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:ImageFile a owl:Class ;
    rdfs:subClassOf cco:ont00000253 .

mds:ImageStack a owl:Class ;
    rdfs:subClassOf cco:ont00000958 .

mds:ImageStackFile a owl:Class ;
    rdfs:subClassOf cco:ont00000253 .

mds:IntegrationID a owl:Class ;
    rdfs:label "integrationID" ;
    rdfs:subClassOf cco:ont00000077 ;
    skos:definition " A unique identifier for a specific integration operation, allowing tracking and referencing of individual integration processes." .

mds:IntegrationOptions a owl:Class ;
    rdfs:label "Integration Configuration" ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:definition "Configuration parameters that control the integration algorithm behavior." .

mds:InterplanarSpacing a owl:Class ;
    rdfs:label "Interplanar Spacing (d-spacing)"@en ;
    rdfs:subClassOf cco:ont00000738 .

mds:IsothermalTransformation a owl:Class ;
    rdfs:label "Isothermal Transformation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty obo:BFO_0000057 ;
            owl:someValuesFrom mds:XraySample ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom cco:DirectiveInformationContentEntity ],
        [ a owl:Restriction ;
            owl:onProperty [ owl:inverseOf cco:ont00001808 ] ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( cco:DirectiveInformationContentEntity [ a owl:Restriction ;
                                owl:onProperty cco:ont00001808 ;
                                owl:someValuesFrom mds:IsothermalHoldTemperature ] ) ] ],
        obo:BFO_0000015 ;
    skos:definition "A heat treatment process where the material is rapidly cooled to a specific temperature and held at that temperature to allow phase transformation to occur."@en .

mds:LaserPowderBedFusion a owl:Class ;
    rdfs:label "Laser Powder Bed Fusion"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty mds:has_increased_likelihood_of ;
            owl:someValuesFrom mds:RapidSolidification ],
        mds:AdditiveManufacturingProcess ;
    skos:altLabel "L-PBF"@en,
        "LPBF"@en,
        "SLM"@en,
        "Selective Laser Melting"@en ;
    skos:definition "An additive manufacturing process in which a focused laser beam selectively melts regions of a powder bed, producing parts with cooling rates typically on the order of 10^3 to 10^6 K/s."@en .

mds:LearningRateSpecification a owl:Class ;
    rdfs:label "Learning Rate Specification"@en ;
    rdfs:comment "An information content entity that specifies the learning rate for gradient descent optimization."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:LeverRule a owl:Class ;
    rdfs:label "Lever Rule"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:PhaseFraction ],
        [ a owl:Restriction ;
            owl:onProperty cco:ont00001808 ;
            owl:someValuesFrom mds:Concentration ],
        mds:GoverningLaw ;
    skos:definition "A thermodynamic relation that determines the phase fractions of two coexisting phases from the overall composition and the phase boundary compositions in a binary or pseudo-binary system."@en .

mds:MaiaDetector a owl:Class ;
    rdfs:label "Maia" ;
    rdfs:subClassOf mds:XrayDetector .

mds:MassiveTransformation a owl:Class ;
    rdfs:label "Massive Transformation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cco:ont00001986 ;
            owl:someValuesFrom mds:EquiaxedMorphology ],
        mds:SolidStatePhaseTransformation ;
    skos:definition "A composition-invariant, thermally activated phase transformation controlled by interface migration rather than long-range diffusion."@en .

mds:MaxBeamSize a owl:Class ;
    rdfs:label "maxBeamSize" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The maximum size of the incoming X-ray beam." .

mds:MaxFrameRate a owl:Class ;
    rdfs:label "Max Frame Rate" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The maximum number of frames the detector can capture per second." .

mds:MethodOfIntegration a owl:Class ;
    rdfs:label "MethodOfIntegration" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "method" ;
    skos:definition "The computational algorithm used for integration." .

mds:ModelInferenceProcess a owl:Class ;
    rdfs:label "Model Inference Process"@en ;
    rdfs:comment "A process of using a trained neural network to make predictions on new data."@en ;
    rdfs:subClassOf cco:ActOfAlgorithmicProcessing .

mds:ModelTestingProcess a owl:Class ;
    rdfs:label "Model Testing Process"@en ;
    rdfs:comment "A process of evaluating a trained neural network model on test data."@en ;
    rdfs:subClassOf cco:ActOfMeasuring .

mds:ModelValidationProcess a owl:Class ;
    rdfs:label "Model Validation Process"@en ;
    rdfs:comment "A process of evaluating a neural network model on validation data during training."@en ;
    rdfs:subClassOf cco:ActOfMeasuring .

mds:ModelWeightsSpecification a owl:Class ;
    rdfs:label "Model Weights Specification"@en ;
    rdfs:comment "An information content entity that represents the learned parameters of a neural network."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:Monochromator a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A crystal-based device that selects a specific wavelength or energy from a polychromatic X-ray beam using Bragg diffraction." .

mds:MonochromatorAngleChi a owl:Class ;
    rdfs:label "Monochromator angle chi" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "mondchi",
        "monuchi" ;
    skos:definition "The chi angle positioning of a monochromator crystal, representing rotation around the axis perpendicular to both the beam and the crystal surface normal." .

mds:MonochromatorAnglePhi a owl:Class ;
    rdfs:label "Monochromator angle phi" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "mondphi",
        "monuphi" ;
    skos:definition "The phi angle positioning of a monochromator crystal, representing rotation around the axis parallel to the crystal surface." .

mds:MonochromatorCrystalSeparation a owl:Class ;
    rdfs:label "Monochromator crystal separation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "monp" ;
    skos:definition "The spatial separation distance between upstream and downstream monochromator crystals." .

mds:MonochromatorOffset a owl:Class ;
    rdfs:label "Mono offset" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "monoff" ;
    skos:definition "The lateral displacement positioning of a monochromator crystal to maintain beam alignment during energy changes." .

mds:MonochromatorPitch a owl:Class ;
    rdfs:label "Monochromator pitch" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "pitch" ;
    skos:definition "The angular adjustment of the downstream monochromator crystal for fine energy tuning." .

mds:MonochromatorRotation a owl:Class ;
    rdfs:label "Mono rotation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:definition "The rotational positioning of a monochromator crystal to select specific X-ray energies through Bragg angle adjustment." .

mds:MonochromatorTransversePosition a owl:Class ;
    rdfs:label "Mono transverse" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "mondx",
        "monux" ;
    skos:definition "The horizontal positioning of a monochromator crystal perpendicular to the beam direction." .

mds:MonochromatorVerticalPosition a owl:Class ;
    rdfs:label "Mono vertical" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "mondz",
        "monuz" ;
    skos:definition "The vertical positioning of a monochromator crystal parallel to the gravitational axis." .

mds:Mythen1k a owl:Class ;
    rdfs:label "Mythen 1k (450um Sensor)" ;
    rdfs:subClassOf mds:XrayDetector .

mds:NanoTerasu a owl:Class ;
    rdfs:label "NanoTerasu" ;
    rdfs:subClassOf mds:SynchrotronFacility ;
    skos:definition "NanoTerasu synchrotron facility in Japan." .

mds:NeuralNetworkArchitectureSpecification a owl:Class ;
    rdfs:label "Neural Network Architecture Specification."@en ;
    rdfs:comment "An information content entity that specifies the structure and configuration of a neural network model."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:NeuralNetworkModelingProcess a owl:Class ;
    rdfs:label "Neural Network Modeling Process"@en ;
    rdfs:comment "A process of designing, training, and evaluating a neural network model."@en ;
    rdfs:subClassOf cco:ActOfAlgorithmicProcessing .

mds:NeuralNetworkTrainingFramework a owl:Class ;
    rdfs:label "Neural Network Training Framework."@en ;
    rdfs:comment "A software artifact used to implement and train neural networks (e.g., TensorFlow, PyTorch)."@en ;
    rdfs:subClassOf cco:ont00000958 .

mds:NeuralNetworkTrainingProcess a owl:Class ;
    rdfs:label "Neural Network Training Process"@en ;
    rdfs:comment "A process of training a neural network by iteratively adjusting weights based on training data."@en ;
    rdfs:subClassOf cco:ActOfAlgorithmicProcessing .

mds:NumberOfPointsAzimuth a owl:Class ;
    rdfs:label "Azimuthal points" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "npt_azimuth" ;
    skos:definition " Number of azimuthal sectors to use for 2D integration." .

mds:NumberOfPointsRadial a owl:Class ;
    rdfs:label "Radial Points" ;
    rdfs:subClassOf cco:ont00000965 ;
    skos:altLabel "npt_radial" ;
    skos:definition "Number of points (bins) in the radial direction of the resulting 1D pattern." .

mds:OpticalTable a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A vibration-isolated platform that supports sample positioning equipment and maintains stable positioning during X-ray measurements." .

mds:OpticalTableHorizontalOrientation a owl:Class ;
    rdfs:label "Optical table horizontal orientation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "txr" ;
    skos:definition "The angular orientation of an optical table around the horizontal axis perpendicular to the beam direction." .

mds:OpticalTableHorizontalPosition a owl:Class ;
    rdfs:label "Optical table horizontal position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "txt" ;
    skos:definition "The horizontal positioning of an optical table perpendicular to the beam direction." .

mds:OpticalTableJack a owl:Class ;
    rdfs:subClassOf cco:ont00000995 ;
    skos:definition "A mechanical jack device that supports and adjusts the height of an optical table." .

mds:OpticalTableJackDownstreamRightPosition a owl:Class ;
    rdfs:label "Optical table jack downstream right position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "zrd" ;
    skos:definition "The vertical positioning of the downstream right jack supporting an optical table." .

mds:OpticalTableJackLeftPosition a owl:Class ;
    rdfs:label "Optical table jack left position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "zl" ;
    skos:definition "The vertical positioning of the left jack supporting an optical table." .

mds:OpticalTableJackUpstreamPosition a owl:Class ;
    rdfs:label "Optical table jack upstream position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "zru" ;
    skos:definition "The vertical positioning of the upstream jack supporting an optical table." .

mds:OpticalTableTransverseOrientation a owl:Class ;
    rdfs:label "Optical table transverse orientation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "tyr" ;
    skos:definition "The angular orientation of an optical table around the axis parallel to the beam direction." .

mds:OpticalTableTransversePosition a owl:Class ;
    rdfs:label "Optical table transverse position" ;
    rdfs:subClassOf cco:ont00000591 ;
    skos:altLabel "tyt" ;
    skos:definition "The positioning of an optical table along the beam direction axis." .

mds:OpticalTableVerticalOrientation a owl:Class ;
    rdfs:label "Optical table vertical orientation" ;
    rdfs:subClassOf obo:BFO_0000019 ;
    skos:altLabel "tzr" ;
    skos:definition "The angular orientation of an optical table around the vertical gravitational axis." .

mds:OrientationDistributionFunction a owl:Class ;
    rdfs:label "Orientation Distribution Function"@en ;
    rdfs:subClassOf cco:ont00000958 ;
    skos:altLabel "ODF"@en ;
    skos:definition "An information content entity that provides a complete quantitative description of the crystallographic texture of a polycrystalline material, giving the volume fraction of crystallites as a function of orientation in Euler angle space."@en .

