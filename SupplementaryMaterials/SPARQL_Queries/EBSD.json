    "sparql_query": "PREFIX mds: <https://cwrusdle.bitbucket.io/mds/>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nSELECT ?sample ?batchNumber ?laserPower ?totalSurfaceRemovalDepth\nWHERE {\n  ?sample a mds:Sample ;\n          mds:hasLaserPower ?laserPower ;\n          mds:hasBatchNumber ?batchNumber ;\n          mds:hasManufacturingMethod ?manufacturingMethod .\n  ?qualityCheck a mds:SampleSurfaceQualityChecks ;\n                mds:isQualityCheckOf ?sample ;\n                mds:hasTotalSurfaceRemovalDepth ?totalSurfaceRemovalDepth .\n  FILTER (?laserPower > 200)\n  FILTER (?totalSurfaceRemovalDepth < 100)\n}\nORDER BY ?batchNumber"
